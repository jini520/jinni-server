spring.application.name=server

# 기본 프로파일 설정
# dev: 개발 환경
# test: 테스트 환경  
# prod: 운영 환경
spring.profiles.active=test

# Jasypt 암호화 설정
# 암호화 키는 환경변수 JASYPT_ENCRYPTOR_PASSWORD로 주입받습니다.
# 예: export JASYPT_ENCRYPTOR_PASSWORD=your-secret-key
# 또는 애플리케이션 실행 시: java -jar app.jar --jasypt.encryptor.password=your-secret-key
jasypt.encryptor.algorithm=PBEWITHHMACSHA512ANDAES_256

# 데이터베이스 설정 (암호화된 값 예시)
# 실제 사용 시: ./scripts/encrypt.sh "your-password" 명령으로 암호화 후 사용
# spring.datasource.url=jdbc:postgresql://localhost:5432/mydb
# spring.datasource.username=myuser
# spring.datasource.password=ENC(암호화된_비밀번호_여기)

# JWT 시크릿 키 (암호화된 값 예시)
# jwt.secret=ENC(암호화된_시크릿_키_여기)

# 주의: 이 파일을 복사해서 application.properties로 만들고
# 필요한 설정을 추가하세요.
# ENC()로 감싼 값은 암호화되어 있어 Git에 올려도 안전합니다.
# 단, 암호화 키(JASYPT_ENCRYPTOR_PASSWORD)는 절대 Git에 올리지 마세요!

